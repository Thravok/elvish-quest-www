<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <meta name="description" content="Elvish Quest — free, privacy-respecting open-source tools hosted for everyone. No accounts, no tracking.">
  
  <!-- Open Graph -->
  <meta property="og:type" content="website">
  <meta property="og:title" content="Elvish Quest">
  <meta property="og:description" content="A sanctuary of open-source privacy tools, freely hosted for wanderers seeking refuge from the ever-watching eyes.">
  <meta property="og:url" content="https://elvish.quest">
  <meta property="og:site_name" content="Elvish Quest">
  
  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary">
  <meta name="twitter:title" content="Elvish Quest">
  <meta name="twitter:description" content="Free, privacy-respecting open-source tools. No accounts, no tracking.">
  
  <!-- Theme -->
  <meta name="theme-color" content="#0a0c0f">
  <meta name="color-scheme" content="dark">
  
  <title>Elvish Quest</title>
  
  <link rel="icon" type="image/svg+xml" href="/favicon.svg">
  <link rel="stylesheet" href="/static/style.css">
</head>
<body>
  <div class="stars" aria-hidden="true"></div>
  <div class="stars stars--layer2" aria-hidden="true"></div>
  <div class="fireflies" aria-hidden="true">
    <div class="firefly"></div>
    <div class="firefly"></div>
    <div class="firefly"></div>
    <div class="firefly"></div>
    <div class="firefly"></div>
    <div class="firefly"></div>
  </div>
  <div class="mist" aria-hidden="true"></div>
  
  <main class="realm">
    <header class="sanctum">
      <div class="rune-circle" aria-hidden="true">
        <svg viewBox="0 0 200 200" class="rune-svg">
          <defs>
            <filter id="glow">
              <feGaussianBlur stdDeviation="3" result="coloredBlur"/>
              <feMerge>
                <feMergeNode in="coloredBlur"/>
                <feMergeNode in="SourceGraphic"/>
              </feMerge>
            </filter>
          </defs>
          <circle cx="100" cy="100" r="90" class="rune-ring rune-ring--outer"/>
          <circle cx="100" cy="100" r="75" class="rune-ring rune-ring--middle"/>
          <circle cx="100" cy="100" r="60" class="rune-ring rune-ring--inner"/>
          <path d="M100 10 L100 25 M100 175 L100 190 M10 100 L25 100 M175 100 L190 100" class="rune-marks"/>
          <path d="M100 35 L118 100 L100 165 L82 100 Z" class="rune-diamond" filter="url(#glow)"/>
          <g class="rune-glyphs">
            <text x="100" y="55" text-anchor="middle" class="rune-glyph">᚛</text>
            <text x="145" y="105" text-anchor="middle" class="rune-glyph">ᚠ</text>
            <text x="100" y="155" text-anchor="middle" class="rune-glyph">᚜</text>
            <text x="55" y="105" text-anchor="middle" class="rune-glyph">ᚢ</text>
          </g>
        </svg>
      </div>
      <p class="whisper">Where privacy finds sanctuary</p>
      <h1 class="title">
        <span class="title-line">Elvish</span>
        <span class="title-line">Quest</span>
      </h1>
      <div class="divider" aria-hidden="true">
        <span class="divider-rune">✧</span>
      </div>
    </header>

    <p class="chronicle">
      A sanctuary of open-source tools, freely hosted for wanderers seeking refuge from the ever-watching eyes. 
      No accounts. No tracking. Just the freedom of the open road.
    </p>

    <section class="artifacts" aria-label="Available Tools">
      <h2 class="sr-only">Tools</h2>
      
      {{range .Tools}}
      <article class="artifact" data-tool="{{.ID}}">
        <div class="artifact-glow"></div>
        <div class="artifact-content">
          <div class="artifact-icon">
            {{.Icon}}
          </div>
          <h3 class="artifact-name">{{.Name}}</h3>
          <p class="artifact-lore">{{.Description}}</p>
          <div class="artifact-actions">
            {{if .URL}}
            <a href="{{.URL}}" class="artifact-link artifact-link--primary" data-tool-name="{{.Name}}">
              {{.Action}} <span class="link-arrow">→</span>
            </a>
            {{else}}
            <span class="artifact-link artifact-link--primary artifact-link--unconfigured" title="Set URL in main.go">
              {{.Action}} <span class="link-arrow">→</span>
            </span>
            {{end}}
            {{if .TorURL}}
            <a href="{{.TorURL}}" class="artifact-link artifact-link--tor" data-tool-name="{{.Name}} (Tor)">
              <svg class="onion-icon" viewBox="0 0 24 24" fill="currentColor" width="14" height="14" aria-hidden="true">
                <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 18c-4.41 0-8-3.59-8-8s3.59-8 8-8 8 3.59 8 8-3.59 8-8 8zm0-14c-3.31 0-6 2.69-6 6s2.69 6 6 6 6-2.69 6-6-2.69-6-6-6zm0 10c-2.21 0-4-1.79-4-4s1.79-4 4-4 4 1.79 4 4-1.79 4-4 4zm0-6c-1.1 0-2 .9-2 2s.9 2 2 2 2-.9 2-2-.9-2-2-2z"/>
              </svg>
              {{.TorAction}}
            </a>
            {{else}}
            <span class="artifact-link artifact-link--tor artifact-link--unconfigured" title="Set TorURL in main.go">
              <svg class="onion-icon" viewBox="0 0 24 24" fill="currentColor" width="14" height="14" aria-hidden="true">
                <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 18c-4.41 0-8-3.59-8-8s3.59-8 8-8 8 3.59 8 8-3.59 8-8 8zm0-14c-3.31 0-6 2.69-6 6s2.69 6 6 6 6-2.69 6-6-2.69-6-6-6zm0 10c-2.21 0-4-1.79-4-4s1.79-4 4-4 4 1.79 4 4-1.79 4-4 4zm0-6c-1.1 0-2 .9-2 2s.9 2 2 2 2-.9 2-2-.9-2-2-2z"/>
              </svg>
              {{.TorAction}}
            </span>
            {{end}}
          </div>
        </div>
      </article>
      {{end}}
    </section>

    <section class="philosophy" aria-labelledby="philosophy-title">
      <div class="philosophy-ornament" aria-hidden="true">⟡</div>
      <h2 id="philosophy-title" class="philosophy-title">Our Covenant</h2>
      <div class="philosophy-content">
        <p>In a realm where every step is watched and every word recorded, we offer sanctuary. These tools exist to return what was always yours: the right to explore, to learn, to search — without being followed.</p>
        <ul class="philosophy-tenets">
          <li><strong>No accounts</strong> — Your identity is your own</li>
          <li><strong>No tracking</strong> — Your path leaves no trace</li>
          <li><strong>No logs</strong> — Your presence is ephemeral</li>
          <li><strong>Open source</strong> — Our magic is yours to inspect</li>
        </ul>
      </div>
    </section>

    <footer class="epilogue">
      <div class="footer-rune" aria-hidden="true">⟡</div>
      <p class="footer-text">Free and open source. No registration required.</p>
      <a href="https://github.com/Thravok/elvish-quest-www" class="source-link">
        <svg viewBox="0 0 24 24" fill="currentColor" width="18" height="18" aria-hidden="true">
          <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
        </svg>
        View Source
      </a>
    </footer>
  </main>

  <script>
    document.querySelectorAll('a.artifact-link').forEach(function(link) {
      link.addEventListener('click', function(e) {
        var name = link.dataset.toolName || 'this tool';
        if (!confirm('You are about to leave Elvish Quest and visit ' + name + '.\n\nContinue?')) {
          e.preventDefault();
        }
      });
    });
  </script>
</body>
</html>
